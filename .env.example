# GEMINI_API_KEY: Optional. Enables Gemini AI responses for the portfolio assistant.
# If omitted, the assistant uses built-in local portfolio responses.
GEMINI_API_KEY=""

# APP_URL: Optional public URL where this portfolio is hosted.
APP_URL=""

# CORS_ORIGIN: Optional. Use your Vercel URL in production, or leave * for public API access.
CORS_ORIGIN="*"

# VITE_API_BASE_URL: Required only when deploying frontend separately from backend.
# Example: https://your-backend-service.onrender.com
VITE_API_BASE_URL="https://portfolio-a538.onrender.com"

# MONGODB_URI: Required to save contact enquiries into your MongoDB cluster.
# For example: mongodb+srv://username:password@cluster.mongodb.net/portfolio
MONGODB_URI=""

# SMTP settings for sending contact enquiries via email.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
# Note: For Gmail, use a Google App Password instead of your regular password.
SMTP_PASS=""
NOTIFICATION_EMAIL=""
