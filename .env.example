# GEMINI_API_KEY: Optional. Enables Gemini AI responses for the portfolio assistant.
# If omitted, the assistant uses built-in local portfolio responses.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Optional public URL where this portfolio is hosted.
APP_URL="MY_APP_URL"

# MONGODB_URI: Required to save contact enquiries into your MongoDB cluster.
# For example: mongodb+srv://username:password@cluster.mongodb.net
MONGODB_URI=""

# SMTP settings for sending contact enquiries via email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
# Note: For Gmail, use a Google App Password instead of your regular password.
SMTP_PASS=""
NOTIFICATION_EMAIL=""

